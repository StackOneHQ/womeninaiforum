<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>Women in AI Forum</title>
		<meta name="description" content="A community for women shaping the future of artificial intelligence. Connect, learn, and lead together." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body>
		<nav>
			<div class="nav-inner">
				<a href="/" class="logo">Women in AI Forum<span class="logo-by"> by StackOne</span></a>
				<div class="nav-links">
					<a href="#about">About</a>
					<a href="#pillars">Pillars</a>
					<a href="#events">Events</a>
					<a href="#join" class="nav-cta">Join the Forum</a>
				</div>
				<button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
			<div class="nav-mobile" aria-hidden="true">
				<a href="#about">About</a>
				<a href="#pillars">Pillars</a>
				<a href="#events">Events</a>
				<a href="#join" class="nav-mobile-cta">Join the Forum</a>
			</div>
		</nav>

		<main>
			<section class="hero">
				<h1>Shaping the future of AI, <em>together</em></h1>
				<p class="hero-sub">A global community dedicated to increasing the representation and influence of women in artificial intelligence.</p>
				<div class="hero-actions">
					<a href="#join" class="btn-primary">Get Involved</a>
					<a href="#about" class="btn-secondary">Learn More</a>
				</div>
				<div class="hero-stats">
					<div class="stat">
						<span class="stat-value">500+</span>
						<span class="stat-label">Members</span>
					</div>
					<div class="stat-divider"></div>
					<div class="stat">
						<span class="stat-value">12</span>
						<span class="stat-label">Countries</span>
					</div>
					<div class="stat-divider"></div>
					<div class="stat">
						<span class="stat-value">48</span>
						<span class="stat-label">Events held</span>
					</div>
				</div>
			</section>

			<section id="about" class="about">
				<div class="section-inner">
					<div class="section-label animate" style="--delay: 0ms">About</div>
					<h2 class="animate" style="--delay: 80ms">AI needs diverse voices at the table</h2>
					<p class="animate" style="--delay: 160ms">Women in AI Forum is a global community dedicated to increasing the representation and influence of women in artificial intelligence. We believe the systems shaping our future should be built by people who reflect the diversity of the world they serve.</p>
					<div class="about-grid">
						<div class="about-card animate" style="--delay: 240ms">
							<div class="card-num">01</div>
							<h3>Connect</h3>
							<p>Meet women across AI research, engineering, product, and policy. Build relationships that accelerate your career.</p>
						</div>
						<div class="about-card animate" style="--delay: 320ms">
							<div class="card-num">02</div>
							<h3>Learn</h3>
							<p>Workshops, reading groups, and technical deep-dives led by practitioners at the frontier of AI.</p>
						</div>
						<div class="about-card animate" style="--delay: 400ms">
							<div class="card-num">03</div>
							<h3>Lead</h3>
							<p>Mentorship programs, speaking opportunities, and pathways to shape AI governance and ethics.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="pillars" class="pillars">
				<div class="section-inner">
					<div class="section-label animate" style="--delay: 0ms">Pillars</div>
					<h2 class="animate" style="--delay: 80ms">What we focus on</h2>
					<div class="pillars-grid">
						<div class="pillar-card pillar-blue animate" style="--delay: 160ms">
							<h3>Research &amp; Development</h3>
							<p>Spotlight original research, collaborate on open problems, and bridge the gap between academia and industry.</p>
						</div>
						<div class="pillar-card pillar-purple animate" style="--delay: 240ms">
							<h3>Ethics &amp; Governance</h3>
							<p>Advocate for responsible AI development, bias auditing, and inclusive policy frameworks.</p>
						</div>
						<div class="pillar-card pillar-cyan animate" style="--delay: 320ms">
							<h3>Career Growth</h3>
							<p>Mentorship circles, job boards, salary transparency, and negotiation workshops tailored to AI careers.</p>
						</div>
						<div class="pillar-card pillar-rose animate" style="--delay: 400ms">
							<h3>Community &amp; Events</h3>
							<p>Monthly meetups, annual summit, hackathons, and a private forum for candid conversation.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="events" class="events">
				<div class="section-inner">
					<div class="section-label animate" style="--delay: 0ms">Upcoming</div>
					<h2 class="animate" style="--delay: 80ms">Events</h2>
					<div class="events-list">
						<div class="event-card animate" style="--delay: 160ms">
							<div class="event-date">
								<span class="event-month">APR</span>
								<span class="event-day">15</span>
							</div>
							<div class="event-info">
								<h3>AI Ethics Roundtable</h3>
								<p>A moderated discussion on bias in large language models with panelists from research and industry.</p>
								<span class="event-meta">Virtual &middot; 6:00 PM GMT</span>
							</div>
						</div>
						<div class="event-card animate" style="--delay: 240ms">
							<div class="event-date">
								<span class="event-month">MAY</span>
								<span class="event-day">03</span>
							</div>
							<div class="event-info">
								<h3>Building with Agents Workshop</h3>
								<p>Hands-on session on designing and deploying agentic AI systems. Bring your laptop.</p>
								<span class="event-meta">London &middot; 2:00 PM GMT</span>
							</div>
						</div>
						<div class="event-card animate" style="--delay: 320ms">
							<div class="event-date">
								<span class="event-month">JUN</span>
								<span class="event-day">21</span>
							</div>
							<div class="event-info">
								<h3>Women in AI Summit 2026</h3>
								<p>Our flagship annual event. Keynotes, workshops, networking, and career fair. Early bird tickets available.</p>
								<span class="event-meta">San Francisco &middot; All Day</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="join" class="join">
				<div class="section-inner">
					<div class="join-content animate" style="--delay: 0ms">
						<div class="section-label join-label">Join</div>
						<h2>Ready to join?</h2>
						<p>Become part of a global network of women driving the AI industry forward. Free to join, open to all who support our mission.</p>
						<a href="mailto:hello@stackone.com" class="btn-primary btn-large">Request an Invite</a>
					</div>
				</div>
			</section>
		</main>

		<footer>
			<div class="footer-inner">
				<span class="footer-logo">Women in AI Forum</span>
				<span class="footer-note">Built by <a href="https://www.stackone.com" target="_blank" rel="noopener">StackOne</a></span>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	:root {
		/* Warm dark palette — violet-tinted, not cold blue-black */
		--bg-primary: #0d0b11;
		--bg-surface: #141220;
		--bg-elevated: #1d1a2a;
		--bg-muted: #18152a;
		--border: #2d2840;
		--border-subtle: #3d3858;

		--text-primary: #f2f0fa;
		--text-secondary: #bbb8d2;
		--text-muted: #7a7690;

		--accent: #7c6df7;
		--accent-dark: #6657e8;
		--accent-light: #bdb5fe;
		--purple: #9b72f7;
		--purple-light: #ccbffe;
		--blue: #4f8ef7;
		--cyan: #22d3ee;
		--rose: #f472b6;

		--font-body: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
		--font-label: 'Inter', sans-serif;

		--radius-sm: 8px;
		--radius-md: 12px;
		--radius-lg: 16px;
		--radius-pill: 77px;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-body);
		background:
			radial-gradient(ellipse 1400px 700px at 50% 0%, rgba(124, 109, 247, 0.06) 0%, transparent 100%),
			var(--bg-primary);
		color: var(--text-primary);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
	}

	/* Nav */
	nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(13, 11, 17, 0.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-bottom: 1px solid var(--border);
	}

	.nav-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 28px;
		height: 72px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		font-size: 15px;
		font-weight: 600;
		color: var(--text-primary);
		text-decoration: none;
		letter-spacing: -0.01em;
	}

	.logo-by {
		color: var(--text-muted);
		font-weight: 400;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 32px;
	}

	.nav-links a {
		font-size: 14px;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.nav-links a:hover {
		color: var(--text-primary);
	}

	.nav-cta {
		background: var(--accent);
		color: var(--text-primary) !important;
		padding: 8px 20px;
		border-radius: var(--radius-pill);
		font-weight: 500;
		font-size: 13px !important;
		transition: background 0.15s ease !important;
	}

	.nav-cta:hover {
		background: var(--accent-dark) !important;
	}

	/* Hero */
	.hero {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 120px 28px 80px;
		max-width: 960px;
		margin: 0 auto;
	}

	.hero h1 {
		font-size: clamp(48px, 8.5vw, 92px);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.04em;
		margin-bottom: 28px;
		animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
	}

	.hero h1 em {
		font-style: normal;
		color: var(--rose);
	}

	.hero-sub {
		font-size: 18px;
		color: var(--text-secondary);
		max-width: 540px;
		margin-bottom: 40px;
		line-height: 1.75;
		font-weight: 400;
		animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
	}

	.hero-actions {
		display: flex;
		gap: 16px;
		margin-bottom: 72px;
		animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
	}

	.hero-stats {
		display: flex;
		align-items: center;
		gap: 48px;
		animation: heroIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
	}

	.stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
	}

	.stat-value {
		font-size: 52px;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
		color: var(--accent-light);
	}

	.stat-label {
		font-size: 13px;
		color: var(--text-muted);
		font-family: var(--font-label);
		letter-spacing: 0.02em;
	}

	.stat-divider {
		width: 1px;
		height: 48px;
		background: var(--border);
	}

	/* Buttons */
	.btn-primary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--accent);
		color: var(--text-primary);
		padding: 12px 28px;
		min-height: 44px;
		border-radius: var(--radius-pill);
		font-size: 14px;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.15s ease;
	}

	.btn-primary:hover {
		background: var(--accent-dark);
	}

	.btn-secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		color: var(--text-secondary);
		padding: 12px 28px;
		min-height: 44px;
		border-radius: var(--radius-pill);
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid var(--border);
		transition: all 0.15s ease;
	}

	.btn-secondary:hover {
		border-color: var(--text-muted);
		color: var(--text-primary);
	}

	.btn-large {
		padding: 16px 36px;
		font-size: 15px;
	}

	/* Sections */
	.section-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 28px;
	}

	.section-label {
		font-family: var(--font-label);
		font-size: 11px;
		font-weight: 600;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin-bottom: 20px;
		display: inline-flex;
		align-items: center;
		gap: 10px;
	}

	.section-label::before {
		content: '';
		display: block;
		width: 20px;
		height: 1px;
		background: currentColor;
		opacity: 0.6;
	}

	section h2 {
		font-size: clamp(32px, 5vw, 52px);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin-bottom: 24px;
		line-height: 1.1;
	}

	section > .section-inner > p {
		font-size: 17px;
		color: var(--text-secondary);
		max-width: 580px;
		line-height: 1.75;
		margin-bottom: 56px;
	}

	/* About */
	.about {
		padding: 140px 0;
	}

	.about-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
	}

	.about-card {
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 36px;
		position: relative;
		overflow: hidden;
		transition: border-color 0.2s ease;
	}

	.card-num {
		font-size: 80px;
		font-weight: 800;
		line-height: 0.9;
		letter-spacing: -0.06em;
		margin-bottom: 20px;
		font-family: var(--font-body);
	}

	/* Each card gets its own watermark color */
	.about-card:nth-child(1) .card-num { color: rgba(124, 109, 247, 0.14); }
	.about-card:nth-child(2) .card-num { color: rgba(155, 114, 247, 0.14); }
	.about-card:nth-child(3) .card-num { color: rgba(244, 114, 182, 0.14); }

	/* Hover reveals each card's color identity */
	.about-card:nth-child(1):hover { background: rgba(124, 109, 247, 0.05); border-color: rgba(124, 109, 247, 0.3); }
	.about-card:nth-child(2):hover { background: rgba(155, 114, 247, 0.05); border-color: rgba(155, 114, 247, 0.3); }
	.about-card:nth-child(3):hover { background: rgba(244, 114, 182, 0.05); border-color: rgba(244, 114, 182, 0.3); }

	.about-card h3 {
		font-size: 20px;
		font-weight: 700;
		margin-bottom: 12px;
		letter-spacing: -0.02em;
	}

	.about-card p {
		font-size: 14px;
		color: var(--text-muted);
		line-height: 1.7;
	}

	/* Pillars */
	.pillars {
		padding: 140px 0;
	}

	.pillars-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
		margin-top: 56px;
	}

	.pillar-card {
		background: var(--bg-surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 36px;
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.pillar-card:hover {
		border-color: var(--border-subtle);
		transform: translateY(-2px);
	}

	.pillar-blue  { border-top: 3px solid var(--blue); }
	.pillar-purple { border-top: 3px solid var(--purple); }
	.pillar-cyan  { border-top: 3px solid var(--cyan); }
	.pillar-rose  { border-top: 3px solid var(--rose); }

	.pillar-card h3 {
		font-size: 20px;
		font-weight: 700;
		margin-bottom: 14px;
		letter-spacing: -0.02em;
	}

	/* Pillar titles take their pillar color */
	.pillar-blue h3  { color: var(--blue); }
	.pillar-purple h3 { color: var(--purple-light); }
	.pillar-cyan h3  { color: var(--cyan); }
	.pillar-rose h3  { color: var(--rose); }

	.pillar-card p {
		font-size: 14px;
		color: var(--text-muted);
		line-height: 1.7;
	}

	/* Events */
	.events {
		padding: 140px 0;
	}

	.events-list {
		display: flex;
		flex-direction: column;
		margin-top: 56px;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.event-card {
		display: flex;
		gap: 32px;
		background: var(--bg-surface);
		padding: 28px 32px;
		transition: background 0.15s ease;
	}

	.event-card + .event-card {
		border-top: 1px solid var(--border);
	}

	.event-card:hover {
		background: var(--bg-elevated);
	}

	.event-date {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-width: 56px;
		gap: 2px;
	}

	.event-month {
		font-family: var(--font-label);
		font-size: 10px;
		font-weight: 600;
		color: var(--accent-light);
		text-transform: uppercase;
		letter-spacing: 0.12em;
	}

	.event-day {
		font-size: 32px;
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--accent-light);
	}

	.event-info h3 {
		font-size: 17px;
		font-weight: 600;
		margin-bottom: 8px;
		letter-spacing: -0.01em;
	}

	.event-info p {
		font-size: 14px;
		color: var(--text-secondary);
		line-height: 1.6;
		margin-bottom: 12px;
	}

	.event-meta {
		font-family: var(--font-label);
		font-size: 12px;
		color: var(--text-muted);
	}

	/* Join */
	.join {
		padding: 140px 0;
		background:
			radial-gradient(ellipse 900px 500px at center, rgba(244, 114, 182, 0.07) 0%, transparent 100%),
			var(--bg-primary);
		border-top: 1px solid rgba(244, 114, 182, 0.12);
		border-bottom: 1px solid rgba(244, 114, 182, 0.12);
	}

	.join-content {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.join-content h2 {
		font-size: clamp(36px, 5.5vw, 60px);
		margin-bottom: 20px;
	}

	.join-content p {
		font-size: 17px;
		color: var(--text-secondary);
		max-width: 460px;
		line-height: 1.75;
		margin-bottom: 40px;
	}

	.join-label {
		color: var(--rose);
		margin-bottom: 24px;
	}

	.join-label::before {
		background: var(--rose);
	}

	/* Footer */
	footer {
		border-top: 1px solid var(--border);
		padding: 28px 0;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 28px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.footer-logo {
		font-size: 14px;
		font-weight: 500;
		color: var(--text-muted);
	}

	.footer-note {
		font-size: 13px;
		color: var(--text-muted);
	}

	.footer-note a {
		color: var(--accent-light);
		text-decoration: none;
	}

	.footer-note a:hover {
		text-decoration: underline;
	}

	/* Animations */
	@keyframes heroIn {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: none;
		}
	}

	.animate {
		opacity: 0;
		transform: translateY(20px);
		transition:
			opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0ms),
			transform 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--delay, 0ms);
	}

	.animate.visible {
		opacity: 1;
		transform: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.animate {
			opacity: 1;
			transform: none;
			transition: none;
		}
		.hero h1,
		.hero-sub,
		.hero-actions,
		.hero-stats {
			animation: none;
		}
	}

	/* Hamburger nav */
	.nav-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
