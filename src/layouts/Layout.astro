---
import '../styles/global.css';
import AgentationOverlay from '../components/AgentationOverlay.tsx';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Women in AI Forum', description = 'Women in AI Forum brings together researchers, practitioners, and advocates to build an equitable AI ecosystem.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400&family=Geist:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <AgentationOverlay client:only="react" />
  </body>
</html>
